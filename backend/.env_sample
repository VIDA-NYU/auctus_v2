# Copy this file to .env and fill in your own values.
#   cp .env.example .env
# .env is git-ignored and must never be committed (it holds your real API key).

# Required: your NYU Portkey gateway API key.
# Used by the arq-worker to call AutoDDG for dataset description generation.
# Get one from the NYU AI Gateway: https://ai-gateway.apps.cloud.rt.nyu.edu
PORTKEY_API_KEY=your-portkey-api-key-here

# Optional overrides (defaults are set in backend/storage/arq_worker.py).
# Uncomment and change only if you need to point at a different gateway/model.
# PORTKEY_BASE_URL=https://ai-gateway.apps.cloud.rt.nyu.edu/v1/
# AUTODDG_MODEL=@vertexai/gemini-2.5-flash
